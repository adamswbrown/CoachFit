<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSHealthShareUsageDescription</key>
	<string>CoachFit reads your workouts, sleep, steps, and weight to share with your coach for fitness tracking.</string>
	<key>NSCameraUsageDescription</key>
	<string>CoachFit uses the camera to scan food barcodes for nutrition tracking.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>CoachFit writes nutrition from scanned foods, water intake, and weight entries to your Health data.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.askadam.CoachFit.healthkit-sync</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
	</dict>
</dict>
</plist>
