# Clerk Authentication (Managed)
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Webhook Signing Secret
# Get from Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Clerk Sign-In/Sign-Up Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# Database
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Email Service (Resend)
RESEND_API_KEY=re_your-resend-api-key
# EMAIL_FROM="CoachFit <noreply@gcgyms.com>"

# Resend Webhook Signature Verification
# Get this from the Resend dashboard when configuring your webhook endpoint
# RESEND_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Admin Override (Emergency Access)
# Set this to grant automatic admin privileges to a specific email address
# ADMIN_OVERRIDE_EMAIL=admin@example.com
